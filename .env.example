# Copie este arquivo para ".env" e preencha com as credenciais do projeto
# Supabase de DESTINO (o que você criou, não o do Lovable Cloud).
# NUNCA commite o arquivo ".env" preenchido.

# Supabase Dashboard -> Project Settings -> API
SUPABASE_PROJECT_ID="<destination-project-ref>"
SUPABASE_URL="https://<destination-project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Necessárias no build do Vite (client-side) — mesmos valores acima
VITE_SUPABASE_PROJECT_ID="<destination-project-ref>"
VITE_SUPABASE_URL="https://<destination-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Somente servidor — NUNCA expor com prefixo VITE_.
# Supabase Dashboard -> Project Settings -> API Keys -> service_role
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Usado por src/lib/gecko.functions.ts (API externa de geocodificação/comparáveis,
# não relacionada ao Supabase — mantenha a mesma chave que já usava)
GECKOAPI_TOKEN="..."

# Usado por src/lib/ai-gateway.server.ts para as análises de IA (Google Gemini
# direto, via @ai-sdk/google). Crie a chave em https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY="..."
